---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;

const description =
  'Autoevaluación de madurez organizacional frente a la Ley 21.719 de protección de datos personales y la gobernanza de datos (MGDE). Autodiagnóstico abierto para toda institución pública de Chile.';
// URL absoluta de la imagen de vista previa: site (dominio) + base (subruta) + archivo público.
const site = Astro.site ?? new URL('https://paulovillarroel.github.io');
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // base sin barra final
const ogImage = new URL(`${base}/portada.png`, site).href;
const canonical = new URL(`${base}/`, site).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    {/* Open Graph / Twitter — vista previa al compartir el enlace */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Autoevaluación de madurez — Ley 21.719 + Gobernanza de datos" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1080" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:image:alt" content="¿Qué tan madura es la gobernanza de datos de tu institución? — Ley 21.719" />
    <meta property="og:locale" content="es_CL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {/* Aplica el tema guardado antes de pintar para evitar parpadeo. */}
    <script is:inline>
      try {
        const t = localStorage.getItem('autoeval-madurez-v1-tema');
        if (t) document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
